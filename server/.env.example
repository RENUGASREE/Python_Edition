# ===========================================
# Python Edition API — Environment Variables
# ===========================================
# Copy to server/.env for local development.
# On Render: set these in Dashboard → Web Service → Environment.

# --- REQUIRED ---
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/python_edition?retryWrites=true&w=majority
JWT_SECRET=use-a-long-random-string-at-least-32-characters

# Frontend URL(s) for CORS — comma-separated, no trailing slash
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- RECOMMENDED (production) ---
NODE_ENV=development
JWT_ACCESS_EXPIRES_IN=15m
AUTO_SEED_ON_STARTUP=true
ADMIN_EMAIL=admin@pythonedition.com
ADMIN_PASSWORD=change-this-admin-password

# --- OPTIONAL ---
PYTHON_BIN=python
TERMINAL_TIMEOUT_MS=30000
TERMINAL_OUTPUT_WAIT_MS=220

# AI tutor (one provider is enough; auto picks first available)
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# AI_PROVIDER=openrouter
# AI_MODEL=google/gemma-2-9b-it:free
# OPENROUTER_SITE_URL=https://your-frontend.onrender.com
# OPENROUTER_APP_NAME=Python Edition

ALLOW_RESET_TOKEN_RESPONSE=false
# Extra protection for POST /api/admin/bootstrap (optional)
# SEED_SECRET=your-private-seed-secret

# --- NOT USED (legacy — do not set for Node stack) ---
# SUPABASE_* — not used by Express/MongoDB app
# DATABASE_URL — not used (was Django/Postgres)
# VITE_* — belongs on frontend build only
